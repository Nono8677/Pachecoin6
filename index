<body>

<!-- ÉCRAN AUTH -->

<div id="auth-screen">
    <h1 class="logo-pache">PACHECOIN</h1>
    <div class="auth-card">
        <div class="auth-tabs">
            <button class="auth-tab active" onclick="showTab('login')">Connexion</button>
            <button class="auth-tab" onclick="showTab('signup')">Inscription</button>
        </div>
        <div id="tab-login">
            <input id="login-email" type="email" placeholder="Email" autocomplete="email">
            <input id="login-pwd" type="password" placeholder="Mot de passe" autocomplete="current-password">
            <button class="auth-btn" onclick="handleLogin()">SE CONNECTER</button>
        </div>
        <div id="tab-signup" style="display:none;">
            <input id="signup-email" type="email" placeholder="Email" autocomplete="email">
            <input id="signup-pwd" type="password" placeholder="Mot de passe (6 caractères min)" autocomplete="new-password">
            <button class="auth-btn" onclick="handleSignup()">CRÉER UN COMPTE</button>
        </div>
        <p id="auth-message"></p>
    </div>
</div>

<!-- APPLI PRINCIPALE -->

<div id="main-app" style="display:none;">
    <header>
        <h1 class="logo-pache">PACHECOIN</h1>
        <div id="market-timer">CLÔTURE : <span id="countdown">--:--:--</span></div>
        <p id="last-update">Chargement des données...</p>
        <button id="logout-btn" onclick="handleLogout()">Déconnexion</button>
    </header>

