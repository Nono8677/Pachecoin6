/* --- VARIABLES ET RESET --- */
:root {
    --bg-dark: #0d1117; /* Fond très noir */
    --card-bg: #161b22; /* Fond des cartes légèrement plus clair */
    --text-primary: #ffffff; /* Texte blanc principal */
    --text-muted: #8b949e; /* Texte grisé pour l'heure/dates */
    --accent-yellow: #f0b90b; /* Jaune Binance/Pachecoin pour le logo/titres */
    --accent-green: #0ecb81; /* Vert "J'achète" */
    --accent-red: #f6465d; /* Rouge "Hors Marché" (pour plus tard) */
    --border-color: #30363d; /* Couleur des bordures fines */
    --font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-family);
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
}

/* --- ÉCRAN D'AUTHENTIFICATION (SI BESOIN) --- */
#auth-screen {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100vh;
    padding: 20px;
}

.auth-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 25px;
    width: 100%;
    max-width: 400px;
    text-align: center;
}

.auth-tabs {
    display: flex;
    margin-bottom: 20px;
    border-bottom: 2px solid var(--border-color);
}

.auth-tab {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-muted);
    padding: 10px;
    cursor: pointer;
    font-weight: 600;
}

.auth-tab.active {
    color: var(--accent-yellow);
    border-bottom: 2px solid var(--accent-yellow);
}

.auth-card input {
    width: 100%;
    background-color: var(--bg-dark);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 12px;
    margin-bottom: 10px;
    border-radius: 8px;
}

.auth-btn {
    width: 100%;
    background-color: var(--accent-yellow);
    color: #000;
    border: none;
    padding: 12px;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    margin-top: 10px;
}

#auth-message {
    margin-top: 15px;
    font-size: 0.9rem;
}

/* --- HEADER ET NAVIGATION (COMME SUR L'IMAGE) --- */
header {
    text-align: center;
    padding: 25px 20px;
}

.logo-pache {
    color: var(--accent-yellow);
    font-size: 2.5rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 15px;
}

#market-timer {
    color: var(--accent-yellow);
    font-size: 1.2rem;
    font-weight: bold;
    margin-bottom: 10px;
}

#last-update {
    color: var(--text-muted);
    font-size: 0.85rem;
}

#logout-btn {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 0.8rem;
    cursor: pointer;
}

/* --- TABS DE NAVIGATION (COMME SUR L'IMAGE) --- */
.tabs {
    display: flex;
    justify-content: center;
    background-color: var(--card-bg);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
}

.nav-tab {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-muted);
    padding: 15px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    max-width: 150px;
}

.nav-tab.active {
    color: var(--accent-yellow);
    border-bottom: 3px solid var(--accent-yellow);
}

/* --- CONTENU PRINCIPAL --- */
main {
    padding: 20px;
    padding-bottom: 80px; /* Espace pour le footer */
}

.tab-content {
    display: none;
}

.tab-content.active {
    display: block;
}

/* --- CONTRÔLES (BOUTON REFRESH ET TIMEFRAME SELON L'IMAGE) --- */
.controls {
    display: flex;
    justify-content: space-between;
    margin-bottom: 20px;
}

#refresh-btn {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1.2rem;
}

#signal-tf-select {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 10px;
    border-radius: 8px;
}

/* --- CARTES CRYPTO (L'ÉLÉMENT CLÉ DE L'IMAGE) --- */
#signals-container {
    display: grid;
    gap: 15px;
}

.crypto-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 20px;
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s;
}

.crypto-card:hover {
    transform: translateY(-3px);
    border-color: #444;
}

.card-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
}

.pair-name {
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--text-primary);
}

.live-price {
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--text-primary);
}

/* --- LE BOUTON VERT "J'ACHÈTE" --- */
.verdict {
    width: 100%;
    padding: 15px;
    border-radius: 12px;
    font-weight: 900;
    text-transform: uppercase;
    text-align: center;
    font-size: 1.2rem;
}

.verdict.buy {
    background-color: var(--accent-green);
    color: #000; /* Texte noir sur fond vert pour lisibilité */
}

.verdict.out {
    background-color: #333;
    color: var(--text-muted);
}

/* Badge BOS optionnel */
.bos-badge {
    display: inline-block;
    margin-top: 10px;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
}
.bos-bull { background-color: rgba(14, 203, 129, 0.2); color: var(--accent-green); }
.bos-bear { background-color: rgba(246, 70, 93, 0.2); color: var(--accent-red); }

/* --- PORTFOLIO CARD (MÊME STYLE QUE L'IMAGE) --- */
.portfolio-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 25px;
    text-align: center;
}

.portfolio-card h3 {
    color: var(--accent-yellow);
    margin-bottom: 15px;
}

.cap-val {
    font-size: 2.2rem;
    font-weight: bold;
    margin-bottom: 10px;
}

.perf-val {
    font-size: 1.2rem;
    font-weight: bold;
}
.perf-val.plus { color: var(--accent-green); }
.perf-val.minus { color: var(--accent-red); }

/* --- FOOTER --- */
footer {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: var(--bg-dark);
    padding: 10px 20px;
    text-align: center;
    border-top: 1px solid var(--border-color);
}

.warning-text {
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.2;
}

/* --- RESPONSIVE MOBILE --- */
@media (max-width: 600px) {
    .logo-pache {
        font-size: 2rem;
    }
    
    .crypto-card {
        padding: 15px;
    }
}
