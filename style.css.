/* --- STYLE GLOBAL --- */
:root {
    --bg-dark: #000000;
    --card-bg: #121212;
    --accent-yellow: #ffb100;
    --accent-green: #0ecb81;
    --text-white: #ffffff;
    --text-gray: #848e9c;
    --border: #2b2f36;
}

body, html {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    background-color: var(--bg-dark);
    color: var(--text-white);
    font-family: 'Inter', -apple-system, sans-serif;
}

/* --- ÉCRAN CONNEXION --- */
#auth-screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
    padding: 20px;
}

.logo-pache {
    color: var(--accent-yellow);
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 30px;
    letter-spacing: 2px;
}

.auth-card {
    background: var(--card-bg);
    padding: 30px;
    border-radius: 16px;
    width: 100%;
    max-width: 350px;
    border: 1px solid var(--border);
}

.auth-tabs {
    display: flex;
    margin-bottom: 25px;
    gap: 10px;
}

.auth-tab {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-gray);
    padding: 10px;
    cursor: pointer;
    font-weight: bold;
    font-size: 0.9rem;
}

.auth-tab.active {
    color: var(--accent-yellow);
    border-bottom: 2px solid var(--accent-yellow);
}

input {
    width: 100%;
    background: #1e2329;
    border: 1px solid var(--border);
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 8px;
    color: white;
    box-sizing: border-box;
}

.auth-btn {
    width: 100%;
    background: var(--accent-yellow);
    color: black;
    border: none;
    padding: 15px;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    text-transform: uppercase;
}

/* --- APP PRINCIPALE --- */
header {
    padding: 20px;
    text-align: center;
}

#market-timer {
    color: var(--accent-yellow);
    font-weight: bold;
    margin: 10px 0;
}

.tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
}

.nav-tab {
    flex: 1;
    padding: 15px;
    background: none;
    border: none;
    color: var(--text-gray);
    font-weight: bold;
}

.nav-tab.active {
    color: var(--accent-yellow);
    border-bottom: 2px solid var(--accent-yellow);
}

/* --- CARTES SIGNAUX --- */
.crypto-card {
    background: var(--card-bg);
    margin: 15px;
    padding: 20px;
    border-radius: 12px;
    border: 1px solid var(--border);
}

.card-info {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    font-weight: bold;
}

.verdict {
    width: 100%;
    padding: 15px;
    border-radius: 8px;
    text-align: center;
    font-weight: 900;
}

.verdict.buy {
    background: var(--accent-green);
    color: black;
}

.verdict.out {
    background: #2b2f36;
    color: var(--text-gray);
}

/* --- FOOTER --- */
footer {
    padding: 20px;
    text-align: center;
    font-size: 0.7rem;
    color: var(--text-gray);
}
