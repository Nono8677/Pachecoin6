/* Suppression des marges par défaut */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Fond noir total et texte blanc */
body {
    background-color: #000000;
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

/* Titre Pachecoin en Jaune Or */
.logo-pache {
    color: #f0b90b;
    text-align: center;
    font-size: 2.5rem;
    font-weight: 900;
    text-transform: uppercase;
    margin: 20px 0;
}

/* Timer et infos */
#market-timer, #last-update {
    text-align: center;
    color: #f0b90b;
    font-weight: bold;
    margin-bottom: 10px;
}

#last-update {
    color: #848e9c;
    font-size: 0.8rem;
}

/* Navigation */
.tabs {
    display: flex;
    justify-content: center;
    border-bottom: 1px solid #2b2f36;
    margin-bottom: 20px;
}

.nav-tab {
    background: none;
    border: none;
    color: #848e9c;
    padding: 15px 20px;
    font-weight: bold;
    cursor: pointer;
}

.nav-tab.active {
    color: #f0b90b;
    border-bottom: 3px solid #f0b90b;
}

/* Cartes des cryptos */
#signals-container {
    padding: 10px;
}

.crypto-card {
    background-color: #121212; /* Gris très foncé */
    border: 1px solid #2b2f36;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 15px;
}

.card-info {
    display: flex;
    justify-content: space-between;
    font-size: 1.2rem;
    font-weight: bold;
    margin-bottom: 15px;
}

/* Bouton J'ACHÈTE Vert */
.verdict.buy {
    background-color: #0ecb81;
    color: #000000;
    text-align: center;
    padding: 12px;
    border-radius: 8px;
    font-weight: 800;
    font-size: 1.1rem;
}

/* Bouton Déconnexion discret */
#logout-btn {
    display: block;
    margin: 0 auto 20px auto;
    background: #2b2f36;
    color: #ffffff;
    border: none;
    padding: 5px 15px;
    border-radius: 5px;
    font-size: 0.8rem;
}

/* Warning en bas */
.warning-text {
    text-align: center;
    font-size: 0.75rem;
    color: #848e9c;
    padding: 20px;
}
