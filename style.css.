:root {
    --bg-dark: #000000;
    --card-bg: #121212;
    --accent-yellow: #f0b90b;
    --accent-green: #0ecb81;
    --text-white: #ffffff;
    --text-gray: #848e9c;
    --border: #2b2f36;
}

body {
    background-color: var(--bg-dark);
    color: var(--text-white);
    font-family: 'Inter', sans-serif;
    margin: 0;
    padding: 0;
}

.logo-pache {
    color: var(--accent-yellow);
    text-align: center;
    font-size: 2.2rem;
    font-weight: 900;
    margin: 20px 0;
}

#market-timer {
    text-align: center;
    color: var(--accent-yellow);
    font-weight: bold;
    font-size: 1.2rem;
    margin-bottom: 5px;
}

#last-update {
    text-align: center;
    color: var(--text-gray);
    font-size: 0.8rem;
    margin-bottom: 20px;
}

/* Onglets */
.tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
}

.nav-tab {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-gray);
    padding: 15px;
    font-weight: bold;
    cursor: pointer;
}

.nav-tab.active {
    color: var(--accent-yellow);
    border-bottom: 2px solid var(--accent-yellow);
}

/* Cartes Crypto */
.crypto-card {
    background-color: var(--card-bg);
    border-radius: 12px;
    padding: 20px;
    margin: 15px;
    border: 1px solid var(--border);
}

.card-info {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    font-size: 1.1rem;
    font-weight: bold;
}

.verdict {
    width: 100%;
    padding: 15px;
    border-radius: 8px;
    text-align: center;
    font-weight: 800;
    font-size: 1.1rem;
    border: none;
}

.verdict.buy {
    background-color: var(--accent-green);
    color: #000;
}

/* Auth */
#auth-screen {
    display: flex;
    flex-direction: column;
    height: 100vh;
    justify-content: center;
    align-items: center;
}

.auth-card {
    background: var(--card-bg);
    padding: 30px;
    border-radius: 15px;
    width: 90%;
    max-width: 400px;
}

.auth-card input {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
    background: #1e2329;
    border: 1px solid var(--border);
    color: white;
    border-radius: 5px;
}

.auth-btn {
    width: 100%;
    padding: 12px;
    background: var(--accent-yellow);
    border: none;
    font-weight: bold;
    border-radius: 5px;
    cursor: pointer;
}
