/* Style Global */
body, html {
    background-color: #000000 !important; /* Force le noir */
    color: #ffffff;
    margin: 0;
    padding: 0;
    font-family: sans-serif;
}

/* Titre Jaune Pachecoin */
.logo-pache {
    color: #f0b90b !important;
    text-align: center;
    font-size: 2.5rem;
    font-weight: 900;
    margin: 20px 0;
    text-transform: uppercase;
}

/* Timer en Jaune */
#market-timer {
    text-align: center;
    color: #f0b90b;
    font-weight: bold;
    font-size: 1.2rem;
}

#last-update {
    text-align: center;
    color: #848e9c;
    font-size: 0.8rem;
    margin-bottom: 20px;
}

/* Cartes des Cryptos */
.crypto-card {
    background-color: #161a1e; /* Gris foncé type Binance */
    border: 1px solid #2b2f36;
    border-radius: 12px;
    padding: 20px;
    margin: 15px;
}

.card-info {
    display: flex;
    justify-content: space-between;
    font-size: 1.1rem;
    font-weight: bold;
    margin-bottom: 15px;
}

/* Bouton J'ACHÈTE Vert */
.verdict.buy {
    background-color: #0ecb81;
    color: #000000;
    text-align: center;
    padding: 12px;
    border-radius: 8px;
    font-weight: bold;
}

/* Boutons de navigation */
.tabs {
    display: flex;
    justify-content: center;
    border-bottom: 1px solid #2b2f36;
}

.nav-tab {
    background: none;
    border: none;
    color: #848e9c;
    padding: 15px;
    font-weight: bold;
}

.nav-tab.active {
    color: #f0b90b;
    border-bottom: 2px solid #f0b90b;
}
